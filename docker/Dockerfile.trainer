FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    UV_SYSTEM_PYTHON=0 \
    VIRTUAL_ENV=/opt/venv \
    LLAMA_CPP_DIR=/opt/llama.cpp \
    PATH="/opt/venv/bin:/root/.cargo/bin:/root/.local/bin:${PATH}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3-pip \
    python3.11-venv \
    git \
    curl \
    build-essential \
    cmake \
    make \
    libcurl4-openssl-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --recursive https://github.com/ggerganov/llama.cpp ${LLAMA_CPP_DIR} && \
    cmake -S ${LLAMA_CPP_DIR} -B ${LLAMA_CPP_DIR}/build \
    -DGGML_CUDA=OFF \
    -DLLAMA_BUILD_EXAMPLES=OFF \
    -DLLAMA_BUILD_TESTS=OFF \
    -DLLAMA_BUILD_SERVER=OFF && \
    cmake --build ${LLAMA_CPP_DIR}/build --config Release --target llama-quantize -j"$(nproc)" && \
    test -x ${LLAMA_CPP_DIR}/build/bin/llama-quantize && \
    ln -sf ${LLAMA_CPP_DIR}/build/bin/llama-quantize ${LLAMA_CPP_DIR}/llama-quantize && \
    ln -sf ${LLAMA_CPP_DIR}/build/bin/llama-quantize ${LLAMA_CPP_DIR}/quantize && \
    ln -sfn ${LLAMA_CPP_DIR} /llama.cpp

RUN curl -LsSf https://astral.sh/uv/install.sh | sh

WORKDIR /workspace

RUN ln -sfn ${LLAMA_CPP_DIR} /workspace/llama.cpp

COPY pyproject.toml ./
COPY scripts/ ./scripts/
COPY data/ ./data/

RUN uv venv ${VIRTUAL_ENV} --python python3.11 && \
    uv pip install --python ${VIRTUAL_ENV}/bin/python \
    "torch==2.4.0" \
    "transformers==4.44.2" \
    "trl==0.11.4" \
    "datasets==2.20.0" \
    "accelerate==0.33.0" \
    "peft==0.12.0" \
    "bitsandbytes==0.43.3" \
    "huggingface_hub==0.24.6" \
    "rich==13.7.1" \
    "setuptools>=68" \
    "unsloth[cu121-torch240]" \
    "requests>=2.32" && \
    ${VIRTUAL_ENV}/bin/python - <<'PY'
import importlib.metadata as md
for pkg in [
    "torch",
    "transformers",
    "trl",
    "bitsandbytes",
    "accelerate",
    "peft",
    "huggingface_hub",
    "rich",
    "setuptools",
    "unsloth",
]:
    print(pkg, md.version(pkg))
from trl.trainer.sft_trainer import SFTTrainer
print("venv smoke test ok")
PY

CMD ["python", "scripts/train_model.py"]