# Agentic Fine-Tuning Pipeline — Docker Environment
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Random key for securing Airflow's web UI session cookies.
AIRFLOW_SECRET_KEY=change-me

# Hugging Face token (needed to download gated models / datasets).
HF_TOKEN=hf_your_token_here

# Absolute path to the project root on the HOST machine.
# DockerOperator uses this to bind-mount data/ and models/ into the trainer.
# Use forward slashes even on Windows.
HOST_PROJECT_ROOT=C:/Users/you/path/to/Nemotron Agentic Fine-Tuning Pipeline

# (Optional) Override the judge model used in evaluate.py.
# JUDGE_MODEL=llama3.2:3b
